# === Wazuh API ===
WAZUH_API_URL=https://tu-wazuh-manager:55000
WAZUH_API_USER=wazuh
WAZUH_API_PASSWORD=wazuh
# Poner en false solo en entornos con certificados válidos
WAZUH_VERIFY_SSL=false

# === Monitoreo ===
# Intervalo en segundos para verificar el estado (default: 60)
ALERT_CHECK_INTERVAL=60
# Máximo de eventos en historial en memoria (default: 200)
HISTORY_MAX_EVENTS=200

# === Notificaciones Telegram ===
# Obtén el token del bot con @BotFather
TELEGRAM_BOT_TOKEN=
# ID del chat o canal donde enviar alertas
TELEGRAM_CHAT_ID=

# === Notificaciones Slack ===
# URL del Incoming Webhook de Slack
SLACK_WEBHOOK_URL=

# === CORS (separar con comas) ===
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
